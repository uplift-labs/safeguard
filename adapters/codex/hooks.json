{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/__SAFEGUARD_PREFIX__/safeguard/adapter-codex/hooks/pre-bash.sh\"",
            "timeout": 10,
            "statusMessage": "Checking Bash command with Safeguard"
          }
        ]
      },
      {
        "matcher": "^(apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/__SAFEGUARD_PREFIX__/safeguard/adapter-codex/hooks/pre-apply-patch.sh\"",
            "timeout": 10,
            "statusMessage": "Checking file edit with Safeguard"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/__SAFEGUARD_PREFIX__/safeguard/adapter-codex/hooks/permission-request.sh\"",
            "timeout": 10,
            "statusMessage": "Checking approval request with Safeguard"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/__SAFEGUARD_PREFIX__/safeguard/adapter-codex/hooks/post-bash.sh\"",
            "timeout": 10,
            "statusMessage": "Recording Bash command with Safeguard"
          }
        ]
      }
    ]
  }
}
